# Environment variables for this Next.js app. Copy to .env.local and fill in.
# Only this .env.example is committed - real .env* files are gitignored.
#
# `.env.schema` is the contract these variables must match, and the quality gate
# fails if this file and the schema drift apart. When you add a variable, declare
# it in both places.
#
# Rules:
# - Server-only secrets have NO prefix and never reach the browser.
# - NEXT_PUBLIC_* is inlined into the client bundle at build time - use it only
#   for values that are safe to expose to every visitor.

# --- Runtime ---
NODE_ENV=development
# Port the server listens on (the platform usually sets PORT).
# PORT=3000

# --- Public (shipped to the browser - no secrets here) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Database (server-only) ---
# DATABASE_URL=postgres://user:password@host:5432/dbname
# Serverless/edge deploys should point at a pooled connection string.
# DATABASE_POOL_URL=

# --- Auth / third-party secrets (server-only, uncomment as needed) ---
# AUTH_SECRET=
# Shared invite code that gates coach self-registration (/signup). Leave unset to
# disable open signup; set it to let coaches register with this code.
# AUTH_INVITE_CODE=
# API_KEY=
